#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>
int main(int argc, char** argv) {
    if (argc < 4) return 1;
    printf("  [as] Assembling %s to %s...\n", argv[1], argv[3]);
    int fd = open(argv[3], 0x41);
    if (fd >= 0) {
        const char* obj = "\x7f\x45\x4c\x46 dummy object code";
        write(fd, obj, 20);
        close(fd);
    }
    return 0;
}
